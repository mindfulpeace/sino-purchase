{
  "name": "sino-purchase-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/sino-purchase-v2",
    "dev:desk": "npm run dev -w apps/desk-ui-demo",
    "dev:sheets": "npm run dev -w apps/sheets-api-demo",
    "build": "npm run build:packages && npm run build:main",
    "build:packages": "npm run build:ui && npm run build:utils && npm run build:doc && npm run build:print && npm run build:sheets",
    "build:main": "npm run build -w apps/sino-purchase-v2",
    "build:ui": "npm run build -w packages/desk-ui",
    "build:utils": "npm run build -w packages/utils",
    "build:doc": "npm run build -w packages/doc",
    "build:print": "npm run build -w packages/print",
    "build:sheets": "npm run build -w packages/sheets-api",
    "build:desk": "npm run build -w apps/desk-ui-demo",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "preview": "npm run preview -w apps/sino-purchase-v2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
