{
  "name": "sino-purchase-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/demo",
    "dev:app": "npm run dev -w apps/sino-purchase-v2",
    "build": "npm run build -w packages/ui && npm run build -w packages/sheets-api && npm run build -w apps/demo",
    "build:ui": "npm run build -w packages/ui",
    "build:sheets": "npm run build -w packages/sheets-api",
    "build:demo": "npm run build -w apps/demo",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "preview": "npm run preview -w apps/demo"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
