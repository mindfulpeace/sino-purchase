{
  "name": "sino-purchase-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/sino-purchase-v2",
    "dev:desk": "npm run dev -w apps/demo-ui",
    "dev:sheets": "npm run dev -w apps/sheets-api-demo",
    "build": "npm run build:packages && npm run build:main",
    "build:packages": "npm run build:utils && npm run build:diff && npm run build:doc-utils && npm run build:sheets-core && npm run build:sheets-react && npm run build:doc && npm run build:print && npm run build:dock",
    "build:dock": "npm run build -w packages/layout-dock",
    "build:main": "npm run build -w apps/sino-purchase-v2",
    "build:ui": "npm run build -w packages/desk-ui",
    "build:utils": "npm run build -w packages/utils",
    "build:diff": "npm run build -w packages/diff",
    "build:doc-utils": "npm run build -w packages/doc-utils",
    "build:doc": "npm run build -w packages/doc-reimburse",
    "build:print": "npm run build -w packages/print",
    "build:sheets-core": "npm run build -w packages/sheets-core",
    "build:sheets-react": "npm run build -w packages/sheets-react",
    "build:desk": "npm run build -w apps/demo-ui",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "preview": "npm run preview -w apps/sino-purchase-v2",
    "deploy": "chmod +x ./scripts/deploy.sh && ./scripts/deploy.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@tanstack/react-virtual": "^3.14.5"
  }
}
